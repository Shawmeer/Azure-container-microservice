# Local development defaults (copy to .env if you want)

# Frontend
FRONTEND_PORT=3000

# Gateway
GATEWAY_PORT=8080
USER_SERVICE_PORT=3001
PRODUCT_SERVICE_PORT=3002

# Gateway -> services (Docker Compose service names)
USER_SERVICE_URL=http://user-service:${USER_SERVICE_PORT}
PRODUCT_SERVICE_URL=http://product-service:${PRODUCT_SERVICE_PORT}

